# SoftAI API — server-only, never expose to the client bundle.
# The playground proxies through /api/analyze, which reads these at runtime.
# (No PUBLIC_ prefix = Vite will NOT inline into client JS.)
SOFTAI_API_URL=https://api.softallthings.com
SOFTAI_API_KEY=sa_live_your_api_key_here

# Cloudflare Turnstile (optional bot check). Leave unset to skip verification.
# - Site key is public (rendered in the browser widget).
# - Secret is server-only (used by /api/analyze to verify the token).
# Get keys at https://dash.cloudflare.com → Turnstile.
# PUBLIC_CF_TURNSTILE_SITEKEY=0x4AAAAAAA...
# CF_TURNSTILE_SECRET=0x4AAAAAAA...

# Resend API key for the support contact form (server-side only).
# Get yours at https://resend.com
RESEND_API_KEY=re_your_api_key_here

---
interface Props {
  active?: string;
}

const { active } = Astro.props;

const categories = [
  { slug: 'gut-health', label: 'Gut Health' },
  { slug: 'stool-analysis', label: 'Stool Analysis' },
  { slug: 'bristol-stool-scale', label: 'Bristol Stool Scale' },
  { slug: 'nutrition', label: 'Nutrition' },
  { slug: 'conditions', label: 'Conditions' },
  { slug: 'app-updates', label: 'App Updates' },
  { slug: 'research', label: 'Research' },
];

const activeClasses = 'px-4 py-2 rounded-full text-sm font-medium bg-[var(--color-primary)] text-[var(--color-text-dark)]';
const inactiveClasses = 'px-4 py-2 rounded-full text-sm font-medium bg-[var(--color-surface)] text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-elevated)] transition-colors border border-[var(--color-border)]/50';
---

<div class="flex flex-wrap gap-2 mb-10">
  <a href="/poopcheck-blog/" class={!active ? activeClasses : inactiveClasses}>
    All
  </a>
  {categories.map((cat) => (
    <a
      href={`/poopcheck-blog/category/${cat.slug}/`}
      class={active === cat.slug ? activeClasses : inactiveClasses}
    >
      {cat.label}
    </a>
  ))}
</div>

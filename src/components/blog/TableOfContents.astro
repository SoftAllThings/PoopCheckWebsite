---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filtered.length > 0 && (
  <nav class="not-prose my-8 p-5 rounded-xl bg-[var(--color-surface)] border border-[var(--color-border)]/50">
    <h2 class="text-sm font-semibold mb-3 text-[var(--color-text)]">Table of Contents</h2>
    <ul class="space-y-1.5">
      {filtered.map((h) => (
        <li class:list={[h.depth === 3 && 'ml-4']}>
          <a
            href={`#${h.slug}`}
            class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors"
          >
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

---
import { SITE } from '../../utils/seo';
---

<section class="py-12 md:py-16" data-hide-sticky-cta>
  <div class="max-w-7xl mx-auto px-5">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-[var(--color-accent)]/10 to-[var(--color-primary)]/10 border border-[var(--color-border)]/50 p-8 md:p-16">
      <!-- Background decoration -->
      <div class="absolute top-0 right-0 w-96 h-96 bg-[var(--color-primary)]/5 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 bg-[var(--color-accent)]/5 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

      <div class="relative text-center max-w-2xl mx-auto">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight">
          Start understanding your
          <span class="gradient-text"> gut today</span>
        </h2>
        <p class="mt-4 text-lg text-[var(--color-text-muted)]">
          Join 25,000+ people who've taken control of their digestive health. Free to download, instant results.
        </p>

        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href={SITE.appStore}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-6 py-3 rounded-xl bg-[var(--color-text)] text-[var(--color-bg)] font-semibold hover:opacity-90 transition-opacity"
          >
            <svg class="w-6 h-6 mr-3" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
            </svg>
            <div class="text-left">
              <div class="text-xs opacity-75">Download on the</div>
              <div class="text-sm font-bold -mt-0.5">App Store</div>
            </div>
          </a>
          <a
            href={SITE.playStore}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-6 py-3 rounded-xl bg-[var(--color-text)] text-[var(--color-bg)] font-semibold hover:opacity-90 transition-opacity"
          >
            <svg class="w-6 h-6 mr-3" viewBox="0 0 24 24" fill="currentColor">
              <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.302 2.302a1 1 0 010 1.38l-2.302 2.302L15.396 12l2.302-2.492zM5.864 2.658L16.8 8.99l-2.302 2.302L5.864 2.658z" />
            </svg>
            <div class="text-left">
              <div class="text-xs opacity-75">Get it on</div>
              <div class="text-sm font-bold -mt-0.5">Google Play</div>
            </div>
          </a>
        </div>

        <p class="mt-6 text-sm text-[var(--color-text-muted)]">
          Free to use &middot; No credit card required &middot; Privacy-first
        </p>
      </div>
    </div>
  </div>
</section>

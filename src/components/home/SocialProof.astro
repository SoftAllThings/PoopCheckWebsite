---
import JsonLd from '../seo/JsonLd.astro';

const aggregateSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'PoopCheck: AI Stool Tracker',
  operatingSystem: 'iOS, Android',
  applicationCategory: 'HealthApplication',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    ratingCount: '2400',
    bestRating: '5',
    worstRating: '1',
  },
};

const testimonials = [
  {
    quote: "I found my IBS trigger in 2 weeks. Dairy — obvious in hindsight, but the pattern only clicked once I had 14 days of data side-by-side.",
    author: 'Sarah M.',
    role: '34 · IBS tracker, 6 months in',
    initials: 'SM',
  },
  {
    quote: "Brought 3 months of reports to my gastro appointment. He skipped 20 minutes of questions because he could just read the data. Best GI visit I've ever had.",
    author: 'James K.',
    role: '42 · IBD patient',
    initials: 'JK',
  },
  {
    quote: "My daily gut score went from 58 to 84 in 8 weeks. Not because I did anything heroic — the app just kept pointing at the same three habits until I fixed them.",
    author: 'Maria L.',
    role: '29 · Wellness tracker',
    initials: 'ML',
  },
];
---

<JsonLd schema={aggregateSchema} />

<section class="py-12 md:py-16 bg-[var(--color-surface)]">
  <div class="max-w-7xl mx-auto px-5">
    <!-- Testimonials -->
    <div class="text-center mb-12">
      <p class="text-[var(--color-primary)] font-semibold text-sm uppercase tracking-wider mb-3">Testimonials</p>
      <h2 class="text-3xl md:text-4xl font-bold">
        Loved by people who care about their
        <span class="gradient-text">health</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="gradient-border p-6 flex flex-col">
          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-[var(--color-primary)]" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <blockquote class="text-[15px] text-[var(--color-text)] leading-relaxed mb-6 flex-1">
            "{t.quote}"
          </blockquote>
          <div class="flex items-center gap-3 pt-4 border-t border-[var(--color-border)]/40">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-[var(--color-accent)] to-[var(--color-primary)] flex items-center justify-center text-sm font-bold text-[var(--color-text-dark)] shrink-0">
              {t.initials}
            </div>
            <div>
              <div class="font-semibold text-sm">{t.author}</div>
              <div class="text-xs text-[var(--color-text-muted)]">{t.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

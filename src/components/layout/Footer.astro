---
import { SITE } from '../../utils/seo';

const footerLinks = {
  Product: [
    { label: 'Features', href: '/features/' },
    { label: 'AI Poop Analyzer', href: '/ai-poop-analyzer/' },
    { label: 'AI Analysis Technology', href: '/ai-stool-analysis-technology/' },
    { label: 'Pricing', href: '/pricing/' },
    { label: 'Live Demo', href: '/demo/' },
    { label: 'For Business', href: '/business/' },
    { label: 'Download', href: '/download/' },
  ],
  Resources: [
    { label: 'Blog', href: '/poopcheck-blog/' },
    { label: 'Guides', href: '/guides/' },
    { label: 'FAQ', href: '/faq/' },
    { label: 'Support', href: '/support/' },
  ],
  Company: [
    { label: 'About', href: '/about-poopcheck/' },
    { label: 'Privacy Policy', href: '/privacy/' },
    { label: 'Terms of Service', href: '/terms/' },
  ],
};

---

<footer class="border-t border-[var(--color-border)]/50 bg-[var(--color-surface)]">
  <div class="max-w-7xl mx-auto px-5">
    <!-- Main footer -->
    <div class="py-16 grid grid-cols-2 md:grid-cols-5 gap-8">
      <!-- Brand column -->
      <div class="col-span-2">
        <a href="/" class="text-xl font-bold">
          <span class="text-[var(--color-text)]">Poop</span><span class="gradient-text">Check</span>
        </a>
        <p class="mt-3 text-[var(--color-text-muted)] text-sm max-w-xs leading-relaxed">
          Understand your gut in seconds. AI-powered stool analysis and gut health tracking for everyone.
        </p>
        <!-- App Store badges -->
        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href={SITE.appStore}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-4 py-2 rounded-lg bg-[var(--color-bg)] border border-[var(--color-border)] text-sm font-medium hover:border-[var(--color-text-muted)] transition-colors"
            aria-label="Download on the App Store"
          >
            <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
            </svg>
            App Store
          </a>
          <a
            href={SITE.playStore}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-4 py-2 rounded-lg bg-[var(--color-bg)] border border-[var(--color-border)] text-sm font-medium hover:border-[var(--color-text-muted)] transition-colors"
            aria-label="Get it on Google Play"
          >
            <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="currentColor">
              <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.302 2.302a1 1 0 010 1.38l-2.302 2.302L15.396 12l2.302-2.492zM5.864 2.658L16.8 8.99l-2.302 2.302L5.864 2.658z" />
            </svg>
            Google Play
          </a>
        </div>
      </div>

      <!-- Link columns -->
      {Object.entries(footerLinks).map(([heading, links]) => (
        <div>
          <h3 class="font-semibold text-sm text-[var(--color-text)] mb-4">{heading}</h3>
          <ul class="space-y-3">
            {links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="py-6 border-t border-[var(--color-border)]/50">
      <p class="text-xs text-[var(--color-text-muted)] text-center">
        &copy; {new Date().getFullYear()} PoopCheck. All rights reserved.
      </p>
    </div>
  </div>
</footer>

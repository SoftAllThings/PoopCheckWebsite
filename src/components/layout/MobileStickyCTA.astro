---
// Mobile-only sticky download bar. Hidden on desktop. Hidden when the footer
// download CTA is in view to avoid stacking two identical CTAs.
---

<div
  id="mobile-sticky-cta"
  class="md:hidden fixed bottom-0 left-0 right-0 z-40 px-3 pb-3 pt-2 bg-gradient-to-t from-[var(--color-bg)] via-[var(--color-bg)]/95 to-transparent transition-transform duration-300"
  data-sticky-cta
>
  <a
    href="/download/"
    class="flex items-center justify-between gap-3 w-full px-5 py-3.5 rounded-full bg-[var(--color-primary)] text-[var(--color-text-dark)] font-semibold text-[15px] shadow-lg shadow-[var(--color-primary)]/20 active:scale-[0.98] transition-transform"
  >
    <span class="flex items-center gap-2">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
      4.8 · Get the app free
    </span>
    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
  </a>
</div>

<script is:inline>
  (() => {
    const bar = document.getElementById('mobile-sticky-cta');
    if (!bar) return;

    const hide = () => bar.style.transform = 'translateY(120%)';
    const show = () => bar.style.transform = 'translateY(0)';

    // Hide initially until user scrolls past the first viewport.
    hide();

    let scrolled = false;
    const onScroll = () => {
      if (!scrolled && window.scrollY > window.innerHeight * 0.35) {
        scrolled = true;
        show();
      } else if (scrolled && window.scrollY <= window.innerHeight * 0.15) {
        scrolled = false;
        hide();
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });

    // Hide when an element tagged [data-hide-sticky-cta] enters the viewport
    // (e.g. the footer DownloadCTA, to avoid double-CTA stacking).
    const targets = document.querySelectorAll('[data-hide-sticky-cta]');
    if (targets.length && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        const anyVisible = entries.some((e) => e.isIntersecting);
        if (anyVisible) hide();
        else if (scrolled) show();
      }, { threshold: 0.1 });
      targets.forEach((t) => io.observe(t));
    }
  })();
</script>

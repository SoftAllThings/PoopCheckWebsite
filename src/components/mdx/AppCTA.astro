---
import { SITE } from '../../utils/seo';
---

<div class="not-prose my-8 p-6 rounded-2xl bg-gradient-to-br from-[var(--color-accent)]/10 to-[var(--color-primary)]/10 border border-[var(--color-border)]/50 text-center">
  <h3 class="text-lg font-bold text-[var(--color-text)] mb-2">Track your gut health with PoopCheck</h3>
  <p class="text-sm text-[var(--color-text-muted)] mb-4">Free AI stool analysis, daily gut score, and personalized insights.</p>
  <div class="flex flex-wrap items-center justify-center gap-3">
    <a
      href={SITE.appStore}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center px-5 py-2.5 rounded-full bg-[var(--color-primary)] text-[var(--color-text-dark)] text-sm font-semibold hover:opacity-90 transition-opacity"
    >
      App Store
    </a>
    <a
      href={SITE.playStore}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center px-5 py-2.5 rounded-full border border-[var(--color-border)] text-[var(--color-text)] text-sm font-semibold hover:bg-[var(--color-surface)] transition-colors"
    >
      Google Play
    </a>
  </div>
</div>

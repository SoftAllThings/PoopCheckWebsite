---
interface Props {
  type?: 'info' | 'warning' | 'tip';
}

const { type = 'info' } = Astro.props;

const styles = {
  info: {
    border: 'border-[var(--color-accent)]',
    bg: 'bg-[var(--color-accent)]/5',
    icon: 'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
    iconColor: 'text-[var(--color-accent)]',
  },
  warning: {
    border: 'border-[var(--color-warning)]',
    bg: 'bg-[var(--color-warning)]/5',
    icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z',
    iconColor: 'text-[var(--color-warning)]',
  },
  tip: {
    border: 'border-[var(--color-primary)]',
    bg: 'bg-[var(--color-primary)]/5',
    icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
    iconColor: 'text-[var(--color-primary)]',
  },
};

const s = styles[type];
---

<aside class:list={['rounded-xl border-l-4 p-4 my-6', s.border, s.bg]}>
  <div class="flex gap-3">
    <svg class:list={['w-5 h-5 shrink-0 mt-0.5', s.iconColor]} fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={s.icon} />
    </svg>
    <div class="text-sm leading-relaxed [&>p]:m-0">
      <slot />
    </div>
  </div>
</aside>

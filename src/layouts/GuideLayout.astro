---
import PageLayout from './PageLayout.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import TableOfContents from '../components/blog/TableOfContents.astro';
import { articleSchema } from '../utils/schema';
import { getCanonicalUrl, SITE } from '../utils/seo';

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  image?: string;
  imageAlt?: string;
  toc?: boolean;
  headings: { depth: number; slug: string; text: string }[];
}

const { title, description, date, updated, image, imageAlt, toc = true, headings } = Astro.props;

const schema = articleSchema({
  title,
  description,
  url: getCanonicalUrl(Astro.url.pathname),
  image: image ? `${SITE.url}${image}` : undefined,
  datePublished: date.toISOString(),
  dateModified: updated?.toISOString(),
});

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<PageLayout
  seo={{
    title,
    description,
    type: 'article',
    image,
    imageAlt,
    publishedTime: date.toISOString(),
    modifiedTime: updated?.toISOString(),
  }}
  schema={schema}
>
  <article class="py-12 md:py-20">
    <div class="max-w-3xl mx-auto px-5">
      <div class="mb-8">
        <Breadcrumbs
          items={[
            { label: 'Guides', href: '/guides/' },
            { label: title, href: Astro.url.pathname },
          ]}
        />
      </div>

      <header class="mb-10">
        <p class="text-[var(--color-primary)] font-semibold text-sm uppercase tracking-wider mb-3">Comprehensive Guide</p>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight">{title}</h1>
        <p class="mt-4 text-lg text-[var(--color-text-muted)] leading-relaxed">{description}</p>
        <div class="mt-4 text-sm text-[var(--color-text-muted)]">
          <span>Published {formattedDate}</span>
          {updated && (
            <span> · Updated {updated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          )}
        </div>
      </header>

      {toc && <TableOfContents headings={headings} />}

      {image && (
        <div class="mb-10 rounded-2xl overflow-hidden">
          <img src={image} alt={imageAlt || title} class="w-full h-auto" loading="eager" />
        </div>
      )}

      <div class="prose prose-invert prose-lg max-w-none
        prose-headings:font-bold prose-headings:text-[var(--color-text)]
        prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-[var(--color-text-muted)] prose-p:leading-relaxed
        prose-a:text-[var(--color-accent)] prose-a:no-underline hover:prose-a:underline
        prose-strong:text-[var(--color-text)]
        prose-code:text-[var(--color-primary)] prose-code:bg-[var(--color-surface)] prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
        prose-blockquote:border-[var(--color-primary)] prose-blockquote:text-[var(--color-text-muted)]
        prose-li:text-[var(--color-text-muted)]
        prose-img:rounded-xl
      ">
        <slot />
      </div>

      <!-- CTA -->
      <div class="mt-16 p-8 rounded-2xl bg-gradient-to-br from-[var(--color-accent)]/10 to-[var(--color-primary)]/10 border border-[var(--color-border)]/50 text-center">
        <h3 class="text-xl font-bold mb-2">Start tracking your gut health</h3>
        <p class="text-sm text-[var(--color-text-muted)] mb-4">Download PoopCheck free and put this knowledge into practice.</p>
        <a
          href="/download/"
          class="inline-flex items-center px-6 py-3 rounded-full bg-[var(--color-primary)] text-[var(--color-text-dark)] font-semibold hover:opacity-90 transition-opacity glow-primary"
        >
          Download Free
        </a>
      </div>
    </div>
  </article>
</PageLayout>

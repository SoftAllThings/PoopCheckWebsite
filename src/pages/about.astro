---
import PageLayout from '../layouts/PageLayout.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import DownloadCTA from '../components/home/DownloadCTA.astro';
import { STATS } from '../utils/seo';
---

<PageLayout
  seo={{
    title: 'About PoopCheck — Our Mission for Better Gut Health',
    description: 'PoopCheck is on a mission to make digestive health tracking accessible, accurate, and private for everyone. Learn about our story and what drives us.',
  }}
>
  <div class="py-12 md:py-20">
    <div class="max-w-3xl mx-auto px-5">
      <div class="mb-8">
        <Breadcrumbs items={[{ label: 'About', href: '/about/' }]} />
      </div>

      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6">
        Making gut health
        <span class="gradient-text">accessible to everyone</span>
      </h1>

      <div class="space-y-8 text-[var(--color-text-muted)] leading-relaxed">
        <p class="text-lg">
          PoopCheck started with a simple observation: your stool is one of the most immediate indicators of your digestive health, yet most people have no systematic way to track it.
        </p>

        <p>
          We built PoopCheck to change that. Using AI and the medically recognized Bristol Stool Scale, we've made it possible to get a comprehensive stool analysis in seconds — no medical degree required.
        </p>

        <h2 class="text-2xl font-bold text-[var(--color-text)] pt-4">Our Mission</h2>
        <p>
          We believe everyone deserves to understand their digestive health. PoopCheck makes it fast, private, and actionable. Our AI has analyzed over {STATS.analyses.long} stool samples, and our community of {STATS.users.long} users proves that people want better tools for health tracking.
        </p>

        <h2 class="text-2xl font-bold text-[var(--color-text)] pt-4">Privacy First</h2>
        <p>
          Health data is sensitive. That's why privacy isn't a feature — it's our foundation. Your photos are encrypted. Your data is never sold. You can delete everything at any time. We built PoopCheck the way we'd want our own health apps built.
        </p>

        <h2 class="text-2xl font-bold text-[var(--color-text)] pt-4">Not a Medical Device</h2>
        <p>
          PoopCheck is a wellness and health tracking tool designed for personal use. It is not a medical device and should not be used to diagnose, treat, or prevent any disease. Always consult a healthcare professional for medical concerns. What PoopCheck does do is give you better data to bring to those conversations.
        </p>
      </div>
    </div>
  </div>

  <DownloadCTA />
</PageLayout>

---
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import { articleSchema, breadcrumbSchema } from '../../utils/schema';
import { getCanonicalUrl, SITE } from '../../utils/seo';
import competitorsData from '../../data/competitors.json';

const url = getCanonicalUrl(Astro.url.pathname);
const title = 'PoopCheck Compared: How It Stacks Up vs Other Stool Tracker Apps';
const description = 'Honest comparisons of PoopCheck vs Cara Care, Dieta Health, Balloon, and other gut-tracking apps. Features, pricing, and who each app is right for.';

const schema = [
  articleSchema({
    title,
    description,
    url,
    datePublished: '2026-04-20T00:00:00Z',
    dateModified: '2026-04-20T00:00:00Z',
    author: 'PoopCheck Team',
    medical: false,
  }),
  breadcrumbSchema([
    { name: 'Home', url: `${SITE.url}/` },
    { name: 'Compare', url },
  ]),
];
---

<PageLayout seo={{ title, description, type: 'article' }} schema={schema}>
  <article class="py-12 md:py-20">
    <div class="max-w-4xl mx-auto px-5">

      <div class="mb-8">
        <Breadcrumbs items={[{ label: 'Compare', href: '/compare/' }]} />
      </div>

      <header class="mb-12">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight">
          PoopCheck Compared
        </h1>
        <p class="mt-4 text-lg text-[var(--color-text-muted)] leading-relaxed">
          Honest side-by-side comparisons with other gut-tracking apps. We'll
          tell you where PoopCheck wins and where a competitor is actually a
          better fit for your needs — because the goal is helping you pick the
          right tool, not sell you ours.
        </p>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
        {competitorsData.competitors.map((c: any) => (
          <a
            href={`/compare/${c.slug}/`}
            class="group relative rounded-2xl border border-[var(--color-border)]/50 bg-[var(--color-surface)] p-6 hover:border-[var(--color-primary)]/50 transition-colors"
          >
            <div class="text-xs font-semibold text-[var(--color-accent)] mb-2">Comparison</div>
            <h2 class="text-xl font-bold mb-3 group-hover:text-[var(--color-primary)] transition-colors">
              PoopCheck vs {c.name}
            </h2>
            <p class="text-sm text-[var(--color-text-muted)]">
              {c.tagline}
            </p>
          </a>
        ))}
      </div>

      <div class="prose prose-invert prose-lg max-w-none
        prose-headings:font-bold prose-headings:text-[var(--color-text)]
        prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
        prose-p:text-[var(--color-text-muted)] prose-p:leading-relaxed
        prose-a:text-[var(--color-accent)] prose-a:no-underline hover:prose-a:underline
        prose-li:text-[var(--color-text-muted)]
      ">
        <h2>What PoopCheck does differently</h2>
        <p>
          Most gut-tracking apps are logs. You select a Bristol type from a
          picker, pick a color, add a note, and hope you remember to do it
          tomorrow. PoopCheck's AI classifies stool directly from a photo — no
          manual selection, no forgotten entries. That single change makes
          daily tracking actually sustainable.
        </p>

        <h2>How to pick the right app for you</h2>
        <ul>
          <li><strong>Managing IBS/IBD with a care team?</strong> A clinician-focused app (like Dieta Health) or dietitian-led program (Cara Care) may integrate better into your workflow.</li>
          <li><strong>Want structured protocols?</strong> Apps like Balloon walk you through guided programs step by step.</li>
          <li><strong>Want effortless tracking + a daily gut-health score?</strong> PoopCheck's AI-first approach is the easiest daily habit to sustain.</li>
          <li><strong>Optimizing rather than managing a diagnosis?</strong> PoopCheck's consumer focus fits better.</li>
        </ul>
      </div>

      <div class="mt-16 p-8 rounded-2xl bg-gradient-to-br from-[var(--color-accent)]/10 to-[var(--color-primary)]/10 border border-[var(--color-border)]/50 text-center">
        <h3 class="text-xl font-bold mb-2">See how PoopCheck feels in practice</h3>
        <p class="text-sm text-[var(--color-text-muted)] mb-4">Free to try, no credit card. First Bristol classification in seconds.</p>
        <a
          href="/download/"
          class="inline-flex items-center px-6 py-3 rounded-full bg-[var(--color-primary)] text-[var(--color-text-dark)] font-semibold hover:opacity-90 transition-opacity glow-primary"
        >
          Download Free
        </a>
      </div>
    </div>
  </article>
</PageLayout>

---
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const guides = (await getCollection('guides'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<PageLayout
  seo={{
    title: 'Guides — Comprehensive Gut Health & Stool Analysis Resources',
    description: 'In-depth guides on gut health, stool analysis, the Bristol Stool Scale, and digestive wellness. Expert-written, evidence-based resources.',
  }}
>
  <div class="py-12 md:py-20">
    <div class="max-w-7xl mx-auto px-5">
      <div class="mb-8">
        <Breadcrumbs items={[{ label: 'Guides', href: '/guides/' }]} />
      </div>

      <div class="max-w-3xl mb-16">
        <h1 class="text-3xl md:text-4xl font-bold">
          Comprehensive <span class="gradient-text">Health Guides</span>
        </h1>
        <p class="mt-4 text-lg text-[var(--color-text-muted)]">
          In-depth, evidence-based guides on gut health, stool analysis, and digestive wellness. Everything you need to understand your body.
        </p>
      </div>

      {guides.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {guides.map((guide) => (
            <a href={`/guides/${guide.id}/`} class="group gradient-border p-8 hover:bg-[var(--color-elevated)] transition-colors">
              <h2 class="text-xl font-semibold mb-3 group-hover:text-[var(--color-primary)] transition-colors">
                {guide.data.title}
              </h2>
              <p class="text-[var(--color-text-muted)] leading-relaxed mb-4">{guide.data.description}</p>
              <div class="flex items-center gap-2 text-sm text-[var(--color-primary)] font-semibold">
                Read guide
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-20">
          <p class="text-[var(--color-text-muted)] text-lg">Comprehensive guides are being written. Check back soon!</p>
        </div>
      )}
    </div>
  </div>
</PageLayout>

const DOC_VERSION = 'v1.0';
const DOC_LAST_UPDATED = '16 May 2026';
---

<PageLayout
  seo={{
    title: 'Health Data Consent',
    description: 'PoopCheck Health Data Consent. The explicit consent we ask you to grant before we process your stool images and symptoms to give you wellness feedback. Covers GDPR Art. 9, MHMDA, CPRA SPI, Quebec Law 25, and other applicable laws.',
  }}
>
  <div class="py-12 md:py-20">
    <div class="max-w-3xl mx-auto px-5">
      <div class="mb-8">
        <Breadcrumbs items={[{ label: 'Health Data Consent', href: '/health-data-consent/' }]} />

---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/home/Hero.astro';
import Features from '../components/home/Features.astro';
import HowItWorks from '../components/home/HowItWorks.astro';
import SocialProof from '../components/home/SocialProof.astro';
import FAQ from '../components/home/FAQ.astro';
import DownloadCTA from '../components/home/DownloadCTA.astro';
import { websiteSchema, softwareApplicationSchema } from '../utils/schema';
import { SITE } from '../utils/seo';

const schemas = [websiteSchema(), softwareApplicationSchema()];
---

<PageLayout
  seo={{
    title: 'AI Poop Analyzer — Scan Your Stool & Track Gut Health',
    description: SITE.description,
  }}
  schema={schemas}
>
  <Hero />
  <HowItWorks />
  <Features />
  <SocialProof />
  <FAQ />
  <DownloadCTA />
</PageLayout>

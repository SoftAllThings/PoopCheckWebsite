---
import PageLayout from '../../../layouts/PageLayout.astro';
import PostCard from '../../../components/blog/PostCard.astro';
import Breadcrumbs from '../../../components/seo/Breadcrumbs.astro';
import CategoryFilter from '../../../components/blog/CategoryFilter.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap((p) => p.data.tags))];
  return tags.map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.tags.includes(tag)))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<PageLayout
  seo={{
    title: `${tag.replace(/-/g, ' ')} articles — PoopCheck Blog`,
    description: `Explore PoopCheck blog articles tagged ${tag.replace(/-/g, ' ')}. Expert, evidence-based insights on digestive health, stool analysis, and gut wellness.`,
  }}
>
  <div class="py-12 md:py-20">
    <div class="max-w-7xl mx-auto px-5">
      <div class="mb-8">
        <Breadcrumbs items={[
          { label: 'Blog', href: '/poopcheck-blog/' },
          { label: `#${tag}`, href: `/poopcheck-blog/tag/${tag}/` },
        ]} />
      </div>

      <div class="max-w-3xl mb-12">
        <h1 class="text-3xl md:text-4xl font-bold">
          Articles tagged <span class="gradient-text">#{tag}</span>
        </h1>
      </div>

      <CategoryFilter />

      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              category={post.data.category}
              slug={post.id}
              image={post.data.image}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-20">
          <p class="text-[var(--color-text-muted)] text-lg">No articles with this tag yet.</p>
        </div>
      )}
    </div>
  </div>
</PageLayout>

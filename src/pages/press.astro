---
import PageLayout from '../layouts/PageLayout.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import { STATS } from '../utils/seo';
---

<PageLayout
  seo={{
    title: 'Press Kit — PoopCheck Media Resources',
    description: 'PoopCheck press kit. Download brand assets, logos, and find key facts about PoopCheck for media coverage.',
  }}
>
  <div class="py-12 md:py-20">
    <div class="max-w-3xl mx-auto px-5">
      <div class="mb-8">
        <Breadcrumbs items={[{ label: 'Press', href: '/press/' }]} />
      </div>

      <h1 class="text-3xl md:text-4xl font-bold mb-4">
        Press <span class="gradient-text">Kit</span>
      </h1>
      <p class="text-lg text-[var(--color-text-muted)] mb-12">
        Media resources and brand assets for covering PoopCheck.
      </p>

      <!-- Key Facts -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold mb-6">Key Facts</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {[
            { label: 'Product', value: 'AI Stool Tracker App' },
            { label: 'Users', value: `${STATS.users.long} worldwide` },
            { label: 'Platforms', value: 'iOS & Android' },
            { label: 'Price', value: 'Free (Premium optional)' },
            { label: 'AI Analyses', value: STATS.analyses.long },
            { label: 'App Store Rating', value: `${STATS.rating} / 5` },
          ].map((fact) => (
            <div class="gradient-border p-4">
              <div class="text-sm text-[var(--color-text-muted)]">{fact.label}</div>
              <div class="font-semibold text-lg">{fact.value}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Boilerplate -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold mb-4">About PoopCheck</h2>
        <div class="text-[var(--color-text-muted)] leading-relaxed space-y-4">
          <p>
            PoopCheck is an AI-powered stool analysis and gut health tracking app used by over 25,000 people worldwide. The app uses computer vision and the Bristol Stool Scale to provide instant stool classification, daily gut health scores, and personalized digestive health insights.
          </p>
          <p>
            Built privacy-first, PoopCheck encrypts all health data and never sells user information. The app is free to download on iOS and Android, with an optional premium subscription for advanced features.
          </p>
        </div>
      </div>

      <!-- Contact -->
      <div class="gradient-border p-8">
        <h2 class="text-xl font-bold mb-2">Media Inquiries</h2>
        <p class="text-[var(--color-text-muted)] mb-4">For press inquiries, interviews, or media assets, contact us:</p>
        <a
          href="mailto:press@poopcheck.app"
          class="text-[var(--color-primary)] font-semibold hover:underline"
        >
          press@poopcheck.app
        </a>
      </div>
    </div>
  </div>
</PageLayout>
